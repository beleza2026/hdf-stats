rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /votos/{fixtureId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /usuarios/{uid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /hinchas/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
